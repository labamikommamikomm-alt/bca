<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.account.closing</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='invoicing_settings']" position="after">
                <h2>Year-End Closing Agent</h2>
                <div class="row mt16 o_settings_container" id="ye_closing_settings">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="retained_earnings_account_id"/>
                            <div class="text-muted">
                                Account to transfer net profit/loss.
                            </div>
                            <field name="retained_earnings_account_id"/>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="closing_journal_id"/>
                            <div class="text-muted">
                                Journal for closing entries.
                            </div>
                            <field name="closing_journal_id"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
