<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="inherit_account_move_in_invoice_tree_payment" model="ir.ui.view">
        <field name="name">account.move.in.invoice.tree.payment</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_in_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_state']" position="after">
                <field name="last_payment_date" optional="show" readonly="1" widget="date"/>
                <field name="last_payment_method_name" optional="show" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="inherit_account_move_out_invoice_tree_sales" model="ir.ui.view">
        <field name="name">account.move.out.invoice.tree.sales</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="invoice_user_id" optional="show" widget="many2one_avatar_user" string="Sales"/>
            </xpath>
            <xpath expr="//field[@name='payment_state']" position="after">
                <field name="payment_date_display" optional="hide" string="Tgl Terbayar"/>
                <field name="payment_method_display" optional="hide" string="Metode Pembayaran"/>
                <field name="total_ppn" optional="hide" string="PPN"/>
                <field name="total_pph" optional="hide" string="PPh"/>
                <field name="total_admin" optional="hide" string="Biaya Admin"/>
                <field name="total_potongan" optional="hide" string="Potongan Penjualan"/>
            </xpath>
        </field>
    </record>
</odoo>
