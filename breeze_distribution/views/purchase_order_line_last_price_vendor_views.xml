<odoo>
    <data>
        <record id="product_last_price_vendor_view_form" model="ir.ui.view">
            <field name="name">product.last.price.vendor.view.form</field>
            <field name="model">product.last.price.vendor</field>
            <field name="arch" type="xml">
                <form string="Last Price per Vendor">
                    <sheet>
                        <group>
                            <field name="product_id"/>
                            <field name="partner_id"/>
                            <field name="last_price"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="product_last_price_vendor_view_tree" model="ir.ui.view">
            <field name="name">product.last.price.vendor.view.tree</field>
            <field name="model">product.last.price.vendor</field>
            <field name="arch" type="xml">
                <tree string="Last Price per Vendor">
                    <field name="product_id"/>
                    <field name="partner_id"/>
                    <field name="last_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                </tree>
            </field>
        </record>

        <record id="product_last_price_vendor_action" model="ir.actions.act_window">
            <field name="name">Last Prices per Vendor</field>
            <field name="res_model">product.last.price.vendor</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_product_last_price_vendor"
                  name="Last Prices per Vendor"
                  parent="purchase.menu_purchase_config"
                  action="product_last_price_vendor_action"
                  sequence="30"/>
    </data>
</odoo>
