<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_rekap_penjualan">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">
            <style>
                .table-rekap {
                    width: 100% !important;
                    table-layout: fixed; /* Memaksa kolom mengikuti width yang ditentukan */
                    border-collapse: collapse;
                }
                .table-rekap th, .table-rekap td {
                    padding: 2px 4px !important; /* Mengecilkan padding agar teks punya ruang */
                    vertical-align: middle !important;
                    word-wrap: break-word;
                }
                .nowrap {
                    white-space: nowrap !important; /* Mencegah angka duit turun ke bawah */
                }
                .text-right {
                    text-align: right !important;
                }
            </style>
            
            <div class="page">
            <div class="text-center" style="border-bottom: 2px solid black; margin-bottom: 20px;">
                        <h3><span t-esc="company_name"/></h3>
                        <h2>REKAP PENJUALAN</h2>
                        <h4 t-if="data.get('customer_id')">Customer: <t t-esc="data['customer_id'][1]"/></h4>
                        <p>
                            Periode: 
                            <span t-esc="data.get('date_from')" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/> 
                            s/d 
                            <span t-esc="data.get('date_to')" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/>
                        </p>
                    </div>
                <table class="table table-sm table-bordered table-rekap">
                    <thead>
                        <tr style="font-size: 9px; background-color: #f2f2f2;">
                            <th style="width: 3%;">NO</th>
                            <th style="width: 7%;">TGL</th>
                            <th style="width: 10%;">FAKTUR</th>
                            <th style="width: 15%;">PRODUK</th>
                            <th style="width: 4%;">QTY</th>
                            <th style="width: 4%;">SAT</th>
                            <th style="width: 8%;">BRUTO/S AT</th>
                            <th style="width: 4%;">DIS C%</th>
                            <th style="width: 8%;">TOT BRUTO</th>
                            <th style="width: 7%;">TOT DISC</th>
                            <th style="width: 8%;">NETTO</th>
                            <th style="width: 8%;">SUBTOTA L</th>
                            <th style="width: 6%;">PPN</th>
                            <th style="width: 8%;">TOTAL</th>
                        </tr>
                    </thead>
                    <tbody style="font-size: 9px;">
                        <t t-foreach="lines" t-as="invoice">
                            <t t-set="invoice_detail_count" t-value="len(invoice['invoice_lines_details'])"/>
                            <t t-foreach="invoice['invoice_lines_details']" t-as="detail">
                                <tr>
                                    <td t-if="detail['idx'] == 0" t-att-rowspan="invoice_detail_count" class="text-center">
                                        <span t-esc="invoice_index + 1"/>
                                    </td>
                                    
                                    <td t-if="detail['idx'] == 0" t-att-rowspan="invoice_detail_count" class="nowrap">
                                        <span t-esc="invoice['tgl_faktur']" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/>
                                    </td>
                                    
                                    <td t-if="detail['idx'] == 0" t-att-rowspan="invoice_detail_count">
                                        <span t-esc="invoice['faktur']"/>
                                    </td>

                                    <td><span t-esc="detail['nama_barang']"/></td>
                                    <td class="text-right"><span t-esc="detail['qty']"/></td>
                                    <td class="text-center"><span t-esc="detail['sat']"/></td>
                                    
                                    <td class="text-right nowrap">
                                        <span t-esc="detail['harga_bruto_per_satuan']" t-options='{"widget": "monetary", "display_currency": invoice["currency_id"]}'/>
                                    </td>
                                    <td class="text-right"><span t-esc="detail['diskon_persen']"/></td>
                                    <td class="text-right nowrap">
                                        <span t-esc="detail['jumlah_bruto']" t-options='{"widget": "monetary", "display_currency": invoice["currency_id"]}'/>
                                    </td>
                                    <td class="text-right nowrap">
                                        <span t-esc="detail['jumlah_diskon']" t-options='{"widget": "monetary", "display_currency": invoice["currency_id"]}'/>
                                    </td>
                                    <td class="text-right nowrap">
                                        <span t-esc="detail['jumlah_netto']" t-options='{"widget": "monetary", "display_currency": invoice["currency_id"]}'/>
                                    </td>

                                    <td t-if="detail['idx'] == 0" t-att-rowspan="invoice_detail_count" class="text-right nowrap">
                                        <span t-esc="invoice['sub_total']" t-options='{"widget": "monetary", "display_currency": invoice["currency_id"]}'/>
                                    </td>
                                    <td t-if="detail['idx'] == 0" t-att-rowspan="invoice_detail_count" class="text-right nowrap">
                                        <span t-esc="invoice['ppn']" t-options='{"widget": "monetary", "display_currency": invoice["currency_id"]}'/>
                                    </td>
                                    <td t-if="detail['idx'] == 0" t-att-rowspan="invoice_detail_count" class="text-right nowrap">
                                        <span t-esc="invoice['total']" t-options='{"widget": "monetary", "display_currency": invoice["currency_id"]}'/>
                                    </td>
                                </tr>
                            </t>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </t>
</template>
</odoo>