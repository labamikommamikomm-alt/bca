<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="report_rekap_pembelian">
    <t t-call="web.html_container">
      <t t-set="data_report_margin_top" t-value="5" />
      <t t-set="data_report_header_spacing" t-value="50" />
      <t t-set="data_report_dpi" t-value="110" />
      <t t-call="web.external_layout">
        <div class="page">
          <div class="text-center">
            <h3>
              <span t-esc="company_name" />
            </h3>
          </div>
          <div class="text-center">
            <h2>LAPORAN DATA PEMBELIAN</h2>
            <p>Periode: <span t-esc="start_date_formatted" /> - <span t-esc="end_date_formatted" /></p>
          </div>
          <div name="tanggal">
            <span t-esc="current_datetime" />
          </div>
          <div name="tabel" class="row">
            <table class="table table-sm table-bordered">
              <thead class="table-primary">
                <tr>
                  <th scope="col">No</th>
                  <th name="th_no_dok" scope="col">No Dok</th>
                  <th name="th_tgl_faktur" scope="col">Tgl Faktur</th>
                  <th name="th_supplier" scope="col">Supplier</th>
                  <th name="th_faktur" scope="col">Faktur</th>
                  <t t-if="data['show_product_info']">
                    <th name="th_nama_barang" scope="col">Nama Barang</th>
                    <th name="th_qty" scope="col">Qty</th>
                    <th name="th_sat" scope="col">Satuan</th>
                    <th name="th_harga" scope="col">Harga</th>
                    <th name="th_jumlah" scope="col">Jumlah</th>
                    <th t-foreach="extra_price_headers" t-as="extra_name" scope="col">
                      <span t-esc="extra_name.upper()" />
                    </th>
                    <th name="th_ppn" scope="col">PPN</th>
                    <th name="th_sub_total" scope="col">Sub Total</th>
                    <th name="th_total" scope="col">Total</th>
                  </t>
                  <t t-else="">
                    <!-- Tanpa Info Barang, urutan: Sub Total, PPN, Extra Price, Total -->
                    <th name="th_sub_total" scope="col">Sub Total</th>
                    <th name="th_ppn" scope="col">PPN</th>
                    <th t-foreach="extra_price_headers" t-as="extra_name" scope="col">
                      <span t-esc="extra_name.upper()" />
                    </th>
                    <th name="th_total" scope="col">Total</th>
                  </t>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="lines" t-as="line" t-as-index="line_index">
                  <t t-if="data['show_product_info']">
                    <t t-foreach="line['product']" t-as="products" t-as-index="prod_index">
                      <tr>
                        <td>
                          <span t-esc="line_index + 1" />
                        </td>
                        <td>
                          <span t-esc="line['no_dok']" />
                        </td>
                        <td>
                          <span t-esc="line['tgl_faktur'].strftime('%d/%m/%Y ')" />
                        </td>
                        <td>
                          <span t-esc="line['supplier']" />
                        </td>
                        <td>
                          <span t-esc="line['faktur']" />
                        </td>
                        <td>
                          <span t-esc="products['nama_barang']" />
                        </td>
                        <td class="text-right">
                          <span t-esc="products['qty']"
                            t-options='{"widget": "float", "precision": 0}' />
                        </td>
                        <td>
                          <span t-esc="products['sat']" />
                        </td>
                        <td class="text-right">
                          <span t-esc="products['harga']"
                            t-options='{"widget": "monetary", "display_currency": currency_id}' />
                        </td>
                        <td class="text-right">
                          <span t-esc="products['jumlah']"
                            t-options='{"widget": "monetary", "display_currency": currency_id}' />
                        </td>
                        <t t-foreach="extra_price_headers" t-as="extra_name">
                          <td class="text-right">
                            <span t-if="prod_index == 0"
                              t-esc="line['extra_costs'].get(extra_name, 0.0)"
                              t-options='{"widget": "monetary", "display_currency": currency_id}' />
                          </td>
                        </t>
                        <td></td>
                        <td></td>
                        <td></td>
                      </tr>
                    </t>
                  </t>
                  <t t-else="">
                    <tr>
                      <td>
                        <span t-esc="line_index + 1" />
                      </td>
                      <td>
                        <span t-esc="line['no_dok']" />
                      </td>
                      <td>
                        <span t-esc="line['tgl_faktur'].strftime('%d/%m/%Y ')" />
                      </td>
                      <td>
                        <span t-esc="line['supplier']" />
                      </td>
                      <td>
                        <span t-esc="line['faktur']" />
                      </td>
                      <td class="text-right">
                        <strong t-esc="line['sub_total']"
                          t-options='{"widget": "monetary", "display_currency": currency_id}' />
                      </td>
                      <td class="text-right">
                        <strong t-esc="line['ppn']"
                          t-options='{"widget": "monetary", "display_currency": currency_id}' />
                      </td>
                      <t t-foreach="extra_price_headers" t-as="extra_name">
                        <td class="text-right">
                          <span t-esc="line['extra_costs'].get(extra_name, 0.0)"
                            t-options='{"widget": "monetary", "display_currency": currency_id}' />
                        </td>
                      </t>
                      <td class="text-right">
                        <strong t-esc="line['total']"
                          t-options='{"widget": "monetary", "display_currency": currency_id}' />
                      </td>
                    </tr>
                  </t>
                  <!-- BARIS TOTAL PER FAKTUR INI HANYA AKAN MUNCUL JIKA OPSI DICENTANG DAN OPSI PRODUKNYA AKTIF (agar tidak ganda dengan single row diatas) -->
                  <t t-if="data['show_invoice_total'] and data['show_product_info']">
                    <tr class="table-info">
                      <td colspan="10" class="text-end">
                        <strong>Total per Faktur:</strong>
                      </td>


                      <t t-foreach="extra_price_headers" t-as="extra_name">
                        <td class="text-right">
                          <strong t-esc="line['extra_costs'].get(extra_name, 0.0)"
                            t-options='{"widget": "monetary", "display_currency": currency_id}' />
                        </td>
                      </t>
                      <td class="text-right">
                        <strong t-esc="line['ppn']"
                          t-options='{"widget": "monetary", "display_currency": currency_id}' />
                      </td>
                      <td class="text-right">
                        <strong t-esc="line['sub_total']"
                          t-options='{"widget": "monetary", "display_currency": currency_id}' />
                      </td>
                      <td class="text-right">
                        <strong t-esc="line['total']"
                          t-options='{"widget": "monetary", "display_currency": currency_id}' />
                      </td>
                    </tr>
                    <tr class="bg-white">
                      <!-- 13 vs 8 cols calculation depends on how many columns are drawn -->
                      <td t-att-colspan="13 if data['show_product_info'] else 8" style="border: none; height: 10px;"></td>
                    </tr>
                  </t>
                </t>
                <tr>
                  <t t-if="data['show_product_info']">
                    <td t-att-colspan="10" class="text-end">
                      <strong>TOTAL:</strong>
                    </td>
                    <t t-foreach="extra_price_headers" t-as="extra_name">
                      <td class="text-right">
                        <strong t-esc="grand_extra_totals.get(extra_name, 0.0)"
                          t-options='{"widget": "monetary", "display_currency": currency_id}' />
                      </td>
                    </t>
                    <td class="text-right">
                      <strong t-esc="grand_ppn"
                        t-options='{"widget": "monetary", "display_currency": currency_id}' />
                    </td>
                    <td class="text-right">
                      <strong t-esc="grand_sub_total"
                        t-options='{"widget": "monetary", "display_currency": currency_id}' />
                    </td>
                    <td class="text-right">
                      <strong t-esc="grand_total_amount"
                        t-options='{"widget": "monetary", "display_currency": currency_id}' />
                    </td>
                  </t>
                  <t t-else="">
                    <td t-att-colspan="5" class="text-end">
                      <strong>TOTAL:</strong>
                    </td>
                    <td class="text-right">
                      <strong t-esc="grand_sub_total"
                        t-options='{"widget": "monetary", "display_currency": currency_id}' />
                    </td>
                    <td class="text-right">
                      <strong t-esc="grand_ppn"
                        t-options='{"widget": "monetary", "display_currency": currency_id}' />
                    </td>
                    <t t-foreach="extra_price_headers" t-as="extra_name">
                      <td class="text-right">
                        <strong t-esc="grand_extra_totals.get(extra_name, 0.0)"
                          t-options='{"widget": "monetary", "display_currency": currency_id}' />
                      </td>
                    </t>
                    <td class="text-right">
                      <strong t-esc="grand_total_amount"
                        t-options='{"widget": "monetary", "display_currency": currency_id}' />
                    </td>
                  </t>
                </tr>
              </tbody>

            </table>
          </div>
        </div>
      </t>
    </t>

  </template>

</odoo>