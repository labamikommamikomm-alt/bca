<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="report_rekap_pembayaran_piutang">
    <t t-call="web.html_container">
      <t t-set="data_report_margin_top" t-value="5"/>
      <t t-set="data_report_header_spacing" t-value="50"/>
      <t t-set="data_report_dpi" t-value="110"/>
      <t t-call="web.external_layout">
        <div class="page">
          <div class="text-center">
            <h3><span t-esc="company_name"/></h3>
          </div>
          <div class="text-center mb-4">
            <h2>LAPORAN PEMBAYARAN PIUTANG</h2>
          </div>
          <div class="row mb-4">
            <div class="col-6">
                <strong>Periode Invoice: </strong>
                <t t-if="data.get('date_from')"><span t-esc="data['date_from']"/></t>
                <t t-else="">-</t>
                s/d
                <t t-if="data.get('date_to')"><span t-esc="data['date_to']"/></t>
                <t t-else="">-</t>
                <br/>
                <strong>Periode Pembayaran: </strong>
                <t t-if="data.get('payment_date_from')"><span t-esc="data['payment_date_from']"/></t>
                <t t-else="">-</t>
                s/d
                <t t-if="data.get('payment_date_to')"><span t-esc="data['payment_date_to']"/></t>
                <t t-else="">-</t>
                <br/>
                <strong>Sales Team / Kolektor: </strong>
                <span t-esc="data.get('team_name', 'Semua')"/>
                  <br/>
                <strong>Bank / Kas: </strong>
                <span t-esc="data.get('journal_name', 'Semua')"/>
            </div>
            <div class="col-6 text-right">
                <strong>Tanggal Cetak: </strong>
                <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
            </div>
          </div>
          <div name="tabel" class="row">
            <table class="table table-sm table-bordered">
              <thead class="table-primary">
                <tr>
                  <th name="th_no" scope="col">No</th>
                  <th name="th_faktur" scope="col">Faktur</th>
                  <th name="th_tgl" scope="col">Tgl</th>
                  <th name="th_customer" scope="col">Customer</th>
                  <th name="th_tgl_lunas" scope="col">Tgl lunas</th>
                  <th name="th_keterangan" scope="col">Keterangan</th>
                  <th name="th_saldo" scope="col">Saldo</th>
                  <t t-foreach="dynamic_tax_names" t-as="tax_name">
                      <th scope="col"><span t-esc="tax_name"/></th>
                  </t>
                  <th name="th_bayar" scope="col">Bayar</th>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="lines" t-as="line">
                  <tr>
                    <t t-set="colspan_val" t-value="6 + len(dynamic_tax_names) + 2"/>
                    <td t-att-colspan="colspan_val">
                     Penagih : <span t-esc="line['penagih']"/>
                    </td>
                  </tr>
                  <t t-foreach="line['lines']" t-as="linex">
                    <tr>
                      <td>
                        <span t-esc="linex_index + 1"/>
                      </td>
                      <td>
                        <span t-esc="linex['faktur']"/>
                      </td>
                      <td>
                        <span t-esc="linex['tanggal'].strftime('%d/%m/%Y ')"/>
                      </td>
                      <td>
                        <span t-esc="linex['customer']"/>
                      </td>
                      <td>
                        <t t-foreach="linex['tgl_lunas']" t-as="tgl_lunas">
                          <span t-esc="tgl_lunas.strftime('%d/%m/%Y ')"/>
                        </t>
                      </td>
                      <td>
                        <span t-esc="linex['keterangan']"/>
                      </td>
                      <td>
                        <span t-esc="linex['saldo']" t-options='{"widget": "monetary", "display_currency": currency_id}'/>
                      </td>
                      <t t-foreach="dynamic_tax_names" t-as="tax_name">
                        <td>
                          <span t-esc="linex['taxes'][tax_name]" t-options='{"widget": "monetary", "display_currency": currency_id}'/>
                        </td>
                      </t>
                      <td>
                        <span t-esc="linex['bayar']" t-options='{"widget": "monetary", "display_currency": currency_id}'/>
                      </td>
                    </tr>
                  </t>
                  <tr class="font-weight-bold table-info">
                    <td colspan="6" class="text-right">Sub Total</td>
                    <td>
                      <span t-esc="line['total_saldo']" t-options='{"widget": "monetary", "display_currency": currency_id}'/>
                    </td>
                    <t t-foreach="dynamic_tax_names" t-as="tax_name">
                      <td>
                        <span t-esc="line['total_taxes'][tax_name]" t-options='{"widget": "monetary", "display_currency": currency_id}'/>
                      </td>
                    </t>
                    <td>
                      <span t-esc="line['total_bayar']" t-options='{"widget": "monetary", "display_currency": currency_id}'/>
                    </td>
                  </tr>
                </t>
                <!-- Grand Total Row -->
                <tr class="font-weight-bold table-success text-dark">
                  <td colspan="6" class="text-right">GRAND TOTAL</td>
                  <td>
                    <span t-esc="grand_total_saldo" t-options='{"widget": "monetary", "display_currency": currency_id}'/>
                  </td>
                  <t t-foreach="dynamic_tax_names" t-as="tax_name">
                    <td>
                      <span t-esc="grand_total_taxes[tax_name]" t-options='{"widget": "monetary", "display_currency": currency_id}'/>
                    </td>
                  </t>
                  <td>
                    <span t-esc="grand_total_bayar" t-options='{"widget": "monetary", "display_currency": currency_id}'/>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <!-- Signatures -->
          <div class="row mt-4">
            <div class="col-4 text-center">
              <p>Admin Piutang</p>
              <br/><br/><br/><br/>
              <hr style="height:1px;border-width:0; color:black; background-color:black;"/>
            </div>
            <div class="col-4 text-center">
              <p>Sales</p>
              <br/><br/><br/><br/>
              <hr style="height:1px;border-width:0; color:black; background-color:black;" />
            </div>
            <div class="col-4 text-center">
              <p>Direktur</p>
              <br/><br/><br/><br/>
              <hr style="height:1px;border-width:0; color:black; background-color:black;" />
            </div>
          </div>
        </div>
      </t>
    </t>

  </template>

</odoo>
