<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="report_rekap_piutang">
    <t t-call="web.html_container">
      <t t-set="data_report_margin_top" t-value="5"/>
      <t t-set="data_report_header_spacing" t-value="50"/>
      <t t-set="data_report_dpi" t-value="110"/>
      <t t-call="web.external_layout">
        <div class="page">
          <div class="text-center">
            <h3>
              <span t-esc="company_name"/>
            </h3>
          </div>
          <div class="text-center">
            <h2>LAPORAN REKAP PIUTANG</h2>
          </div>
          <div name="header" class="row mb-4">
            <div class="col-6">
                <strong>Periode: </strong>
                <t t-if="data.get('date_from')"><span t-esc="data['date_from']"/></t>
                <t t-else="">-</t>
                s/d
                <t t-if="data.get('date_to')"><span t-esc="data['date_to']"/></t>
                <t t-else="">-</t>
                <br/>
                <strong>Customer: </strong>
                <t t-if="data.get('partner_name')"><span t-esc="data['partner_name']"/></t>
                <t t-else="">Semua</t>
                <br/>
                <strong>Sales Team / Kolektor: </strong>
                <t t-if="data.get('team_name')"><span t-esc="data['team_name']"/></t>
                <t t-else="">Semua</t>
                <br/>
                <strong>Status Pembayaran: </strong>
                <t t-if="data.get('payment_state') == 'not_paid'">Not Paid</t>
                <t t-elif="data.get('payment_state') == 'paid'">Paid</t>
                <t t-elif="data.get('payment_state') == 'partial'">Partially Paid</t>
                <t t-elif="data.get('payment_state') == 'in_payment'">In Payment</t>
                <t t-else="">Semua (All)</t>
            </div>
            <div class="col-6 text-right">
                <strong>Tanggal Cetak: </strong>
                <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
            </div>
        </div>
        <div name="tabel" class="row">
          <table class="table table-sm table-bordered">
            <thead class="table-primary">
              <tr>
                <th name="th_no" scope="col">No</th>
                <th name="th_nota_penjualan" scope="col">Nota Penjualan</th>
                <th name="th_tanggal_jual" scope="col">Tanggal Jual</th>
                <th name="th_customer" scope="col">Customer</th>
                <th name="th_piutang" scope="col">Piutang</th>
                <th name="th_terbayar" scope="col">Terbayar</th>
                <th name="th_sisa_piutang" scope="col">Sisa Piutang</th>
                <th name="th_sales" scope="col">Sales</th>
                <th name="th_kota" scope="col">Kota</th>
                <th name="th_keterangan" scope="col">Keterangan</th>
              </tr>
            </thead>
            <tbody>
              <!-- <t t-set="no" t-value="1"/> -->
              <!-- <t t-set="jumlah_terbayar" t-value="0"/> -->
              <t t-foreach="lines" t-as="line">
                <tr>
                  <td>
                    <span t-esc="line_index + 1"/>
                  </td>
                  <td>
                    <span t-esc="line['no_faktur']"/>
                  </td>
                  <td>
                    <span t-esc="line['tanggal_faktur'].strftime('%d/%m/%Y ')"/>
                  </td>
                  <td>
                    <span t-esc="line['customer']"/>
                  </td>
                  <td>
                    <span t-esc="line['jumlah']" t-options='{"widget": "monetary", "display_currency": line["currency_id"]}'/>
                  </td>
                  <td>
                    <span t-esc="line['terbayar']" t-options='{"widget": "monetary", "display_currency": line["currency_id"]}'/>
                  </td>
                  <td>
                    <span t-esc="line['sisa']" t-options='{"widget": "monetary", "display_currency": line["currency_id"]}'/>
                  </td>
                  <td>
                    <span t-esc="line['sales']"/>
                  </td>
                  <td>
                    <span t-esc="line['wilayah']"/>
                  </td>
                  <td>
                    <span t-esc="line['keterangan']"/>
                  </td>
                </tr>
              </t>
              <!-- Grand Total Row -->
              <tr class="font-weight-bold table-info">
                <td colspan="4" class="text-right">Grand Total</td>
                <td><span t-esc="total_piutang" t-options='{"widget": "monetary", "display_currency": currency_id}'/></td>
                <td><span t-esc="total_terbayar" t-options='{"widget": "monetary", "display_currency": currency_id}'/></td>
                <td><span t-esc="total_sisa" t-options='{"widget": "monetary", "display_currency": currency_id}'/></td>
                <td colspan="3"></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="row mt-4">
          <div class="col-4 text-center">
            <p>Admin Piutang</p>
            <br/>
            <br/>
            <br/>
            <br/>
            <hr style="height:1px;border-width:0; color:black; background-color:black;"/>
          </div>
          <div class="col-4 text-center">
            <p>Sales</p>
            <br/>
            <br/>
            <br/>
            <br/>
            <hr style="height:1px;border-width:0; color:black; background-color:black;" />
          </div>
          <div class="col-4 text-center">
            <p>Direktur</p>
            <br/>
            <br/>
            <br/>
            <br/>
            <hr style="height:1px;border-width:0; color:black; background-color:black;" />
          </div>
        </div>
      </div>
    </t>
  </t>

</template>

</odoo>
