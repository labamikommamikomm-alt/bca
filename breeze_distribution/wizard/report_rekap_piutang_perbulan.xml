<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="report_rekap_piutang_perbulan_view" model="ir.ui.view">
        <field name="name">Rekap Piutang Perbulan</field>
        <field name="model">report.rekap_piutang_perbulan</field>
        <field name="arch" type="xml">
            <form string="Report Options">
                <group col="4">
                    <field name="year"/>
                </group>
                <footer>
                    <button name="check_report" string="Print PDF" type="object" default_focus="1" class="oe_highlight" icon="fa-print"/>
                    <button name="export_excel" string="Export Excel" type="object" class="btn-success" icon="fa-file-excel-o"/>
                    <button string="Cancel" class="btn btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_piutang_perbulan_menu" model="ir.actions.act_window">
        <field name="name">Rekap Piutang Perbulan</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">report.rekap_piutang_perbulan</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="report_rekap_piutang_perbulan_view"/>
        <field name="target">new</field>
    </record>

    <menuitem
            id="menu_piutang_perbulan"
            name="Rekap Piutang Perbulan"
            sequence="11"
            parent="breeze_distribution.menu_finance_atmu_reports"
            action="action_piutang_perbulan_menu"
            groups="account.group_account_user,account.group_account_manager"
    />

</odoo>
