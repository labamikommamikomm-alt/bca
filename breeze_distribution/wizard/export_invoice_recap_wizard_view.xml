<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="export_invoice_recap_wizard_view" model="ir.ui.view">
        <field name="name">export.invoice.recap.wizard.form</field>
        <field name="model">export.invoice.recap.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Rekap Invoice">
                <group class="oe_title">
                    <field name="judul" colspan="2"/>
                </group>
                <div class="alert alert-info" role="alert" style="margin-top: 10px;">
                    Laporan akan dibuat berdasarkan invoice yang Anda pilih (centang) pada daftar invoice sebelumnya.
                </div>
                <footer>
                    <button name="action_print_pdf" string="Print PDF" type="object" class="btn-primary" icon="fa-print"/>
                    <button name="action_export_excel" string="Export Excel" type="object" class="btn-success" icon="fa-file-excel-o"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_export_invoice_recap_wizard" model="ir.actions.act_window">
        <field name="name">Export Rekap Invoice</field>
        <field name="res_model">export.invoice.recap.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="export_invoice_recap_wizard_view"/>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>
