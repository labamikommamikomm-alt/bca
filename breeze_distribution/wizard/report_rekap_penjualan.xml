<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="report_rekap_penjualan_view" model="ir.ui.view">
        <field name="name">Rekap Penjualan</field>
        <field name="model">report.rekap_penjualan</field>
        <field name="arch" type="xml">
            <form string="Report Options">
                <group>
                    <group>
                        <field name="filter_type" widget="radio" options="{'horizontal': true}"/>
                        <field name="customer_id" options="{'no_create': True}"/>
                    </group>
                    <group attrs="{'invisible': [('filter_type', '!=', 'period')]}">
                        <field name="date_from" attrs="{'required': [('filter_type', '=', 'period')]}"/>
                        <field name="date_to" attrs="{'required': [('filter_type', '=', 'period')]}"/>
                    </group>
                </group>
                <footer>
                    <button name="check_report" string="Print PDF" type="object" class="oe_highlight" icon="fa-print"/>
                    <button name="export_excel" string="Export Excel" type="object" class="btn-success" icon="fa-file-excel-o"/>
                    <button name="preview_report" string="Preview" type="object" class="btn-success" icon="fa-file-excel-o"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_rekap_penjualan_wizard" model="ir.actions.act_window">
        <field name="name">Rekap Penjualan</field>
        <field name="res_model">report.rekap_penjualan</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="report_rekap_penjualan_action" model="ir.actions.report">
        <field name="name">Rekap Penjualan</field>
        <field name="model">report.rekap_penjualan</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">breeze_distribution.report_rekap_penjualan</field>
        <field name="report_file">breeze_distribution.report_rekap_penjualan</field>
        <field name="binding_model_id" ref="model_report_rekap_penjualan"/>
        <field name="binding_type">report</field>
    </record>

    <menuitem id="menu_rekap_penjualan"
              name="Rekap Penjualan"
              parent="sale.menu_sale_report"
              action="action_rekap_penjualan_wizard"
              sequence="10"/>
</odoo>